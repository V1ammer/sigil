{"nodes": [{"id": "client_readme_messenger_client", "label": "Messenger Client (web / desktop / Android)", "file_type": "document", "source_file": "client/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cross-platform client built once in Rust/WASM: web via trunk serve, desktop via Tauri 2, mobile via Tauri Mobile (Android only; iOS unsupported). Target minimum Android 10 (API 29), minSdk 24."}, {"id": "client_readme_android_keystore_plugin", "label": "tauri-plugin-android-keystore", "file_type": "concept", "source_file": "client/README.md", "source_location": "## Android Keystore Plugin", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Custom Tauri plugin for secure secret storage on Android using EncryptedSharedPreferences with MasterKey (AES-256 GCM) for hardware-backed encryption. setUserAuthenticationRequired(false) \u2014 biometric auth deliberately not implemented for MVP."}, {"id": "client_readme_encryptedsharedpreferences", "label": "EncryptedSharedPreferences (androidx.security.crypto)", "file_type": "concept", "source_file": "client/README.md", "source_location": "## Android Keystore Plugin", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "client_readme_sqlcipher", "label": "SQLCipher local DB encryption (desktop only)", "file_type": "rationale", "source_file": "client/README.md", "source_location": "## \u0418\u0437\u0432\u0435\u0441\u0442\u043d\u044b\u0435 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u044f", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Desktop uses SQLCipher for local DB encryption; Android uses stock bundled SQLite WITHOUT SQLCipher because building SQLCipher would require cross-compiling OpenSSL for Android. Trade-off: sensitive data on Android is instead protected via EncryptedSharedPreferences (Keystore plugin)."}, {"id": "client_readme_os_keyring", "label": "OS keyring for desktop key storage", "file_type": "concept", "source_file": "client/README.md", "source_location": "### Desktop", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Desktop stores keys in the operating-system keyring via the `keyring` crate \u2014 the desktop counterpart of the Android keystore plugin."}, {"id": "client_readme_fcm_push_deferred", "label": "FCM background push (deferred to post-MVP)", "file_type": "rationale", "source_file": "client/README.md", "source_location": "### Android", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Android app receives no notifications in background: delivery currently relies on a WebSocket that only works in foreground. Firebase Cloud Messaging is required but deferred until post-MVP; server-side models and migrations are ready, routes are not implemented."}], "edges": [{"source": "client_readme_messenger_client", "target": "client_readme_android_keystore_plugin", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "client/README.md", "source_location": "## Android Keystore Plugin", "weight": 1.0}, {"source": "client_readme_android_keystore_plugin", "target": "client_readme_encryptedsharedpreferences", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "client/README.md", "source_location": "## Android Keystore Plugin", "weight": 1.0}, {"source": "client_readme_messenger_client", "target": "server_readme_messenger_server", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "client/README.md", "source_location": null, "weight": 1.0}, {"source": "client_readme_fcm_push_deferred", "target": "server_readme_messenger_server", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "client/README.md", "source_location": "### Android: FCM \u2014 \u0441\u0435\u0440\u0432\u0435\u0440\u043d\u0430\u044f \u0447\u0430\u0441\u0442\u044c \u0433\u043e\u0442\u043e\u0432\u0430, \u0440\u043e\u0443\u0442\u044b \u043d\u0435 \u0440\u0435\u0430\u043b\u0438\u0437\u043e\u0432\u0430\u043d\u044b", "weight": 1.0}, {"source": "client_readme_fcm_push_deferred", "target": "client_readme_messenger_client", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "client/README.md", "source_location": "## \u0418\u0437\u0432\u0435\u0441\u0442\u043d\u044b\u0435 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u044f", "weight": 1.0}, {"source": "client_readme_sqlcipher", "target": "client_readme_encryptedsharedpreferences", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "client/README.md", "source_location": "### Android: \u0428\u0438\u0444\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0411\u0414", "weight": 1.0}, {"source": "client_readme_os_keyring", "target": "client_readme_android_keystore_plugin", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "client/README.md", "source_location": "### Desktop", "weight": 1.0}], "hyperedges": [{"id": "platform_data_at_rest_protection", "label": "Platform-specific data-at-rest protection strategy", "nodes": ["client_readme_android_keystore_plugin", "client_readme_encryptedsharedpreferences", "client_readme_os_keyring", "client_readme_sqlcipher"], "relation": "form", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "client/README.md"}]}