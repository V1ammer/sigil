{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Messenger",
  "version": "0.1.0",
  "identifier": "com.example.messenger",
  "build": {
    "frontendDist": "../crates/messenger-client/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ../crates/messenger-client && trunk serve --port 1420",
    "beforeBuildCommand": "cd ../crates/messenger-client && trunk build --release"
  },
  "app": {
    "windows": [
      {
        "title": "Messenger",
        "width": 1100,
        "height": 720,
        "minWidth": 360,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
